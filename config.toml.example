soul_path = "/etc/flint/soul.yaml"
db_path = "/etc/flint/memories.duckdb"
primary_contact = "user"
poll_interval_secs = 3

[claude]
# api_key loaded from ANTHROPIC_API_KEY env var
model = "claude-sonnet"
max_tokens = 4096
context_limit = 200000
compaction_threshold = 0.75

[signal]
phone_number = "+15551234567"
allowed_senders = ["+15559876543"]

[memory]
max_memories = 10000
top_k_retrieval = 10
importance_decay_days = 30.0
min_importance_to_keep = 0.1
ttl_days_episodic = 90

[heartbeat]
interval_secs = 3600
